rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Helpers (Simplified)
    // ===============================================================
    function isValidFavorite(data) {
      return data.keys().hasAll(['uid', 'title', 'lyrics', 'prompt', 'appliedKeywords', 'isLocked', 'createdAt']) &&
             data.uid is string &&
             data.title is string &&
             data.lyrics is map &&
             data.prompt is string &&
             data.appliedKeywords is map &&
             data.isLocked is bool &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.role in ['free', 'basic', 'pro', 'admin'] &&
             data.accountStatus in ['active', 'paused', 'expired', 'banned'] &&
             data.paymentStatus in ['none', 'active', 'canceled', 'expired', 'refunded', 'trial'];
    }

    function isValidRecentSongs(data) {
      return data.keys().hasAll(['songs']) &&
             data.songs is list &&
             data.songs.size() <= 5;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(uid) && incoming().role == 'free';
      allow update: if isAdmin() || (isOwner(uid) && incoming().role == existing().role && incoming().accountStatus == existing().accountStatus);
    }

    match /favorites/{favoriteId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isOwner(incoming().uid) && isValidFavorite(incoming());
      allow delete: if isOwner(existing().uid) || isAdmin();
      allow update: if (isOwner(existing().uid) || isAdmin()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['isLocked']);
    }

    match /user_recent_songs/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid) && isValidRecentSongs(incoming());
      allow delete: if isOwner(uid) || isAdmin();
    }

    match /section_tags/{tagId} {
      // Tags are public information for the UI
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /section_tags_draft/{tagId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /section_tags_live/{tagId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}
