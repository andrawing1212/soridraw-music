{
  "entities": {
    "Favorite": {
      "title": "Favorite Song",
      "description": "A song that a user has marked as a favorite.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The UID of the user who favorited the song."
        },
        "title": {
          "type": "string",
          "description": "The title of the song."
        },
        "lyrics": {
          "type": "object",
          "description": "The lyrics of the song in English and Korean.",
          "properties": {
            "english": { "type": "string" },
            "korean": { "type": "string" }
          }
        },
        "prompt": {
          "type": "string",
          "description": "The music generation prompt."
        },
        "appliedKeywords": {
          "type": "object",
          "description": "The keywords used to generate the song.",
          "properties": {
            "genre": { "type": "array", "items": { "type": "string" } },
            "mood": { "type": "array", "items": { "type": "string" } },
            "theme": { "type": "array", "items": { "type": "string" } },
            "tempo": { "type": "string" },
            "vocalType": { "type": "string" },
            "lyricsLength": { "type": "string" },
            "drumStyle": { "type": "string" },
            "maleCount": { "type": "number" },
            "femaleCount": { "type": "number" },
            "tempoConfig": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "min": { "type": "number" },
                "max": { "type": "number" }
              }
            }
          }
        },
        "isLocked": {
          "type": "boolean",
          "description": "Whether the favorite is locked from deletion."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the favorite was created."
        }
      },
      "required": ["uid", "title", "lyrics", "prompt", "appliedKeywords", "isLocked", "createdAt"]
    },
    "RecentSongs": {
      "title": "Recent Songs",
      "description": "A list of the 5 most recent songs generated by a user.",
      "type": "object",
      "properties": {
        "songs": {
          "type": "array",
          "items": { "$ref": "Favorite" },
          "description": "The list of recent songs."
        }
      },
      "required": ["songs"]
    },
    "SectionTag": {
      "title": "Section Tag",
      "description": "A tag that can be applied to a song section.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "tier": { "type": "string", "enum": ["free", "basic", "pro"] },
        "sections": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "label", "description", "tier", "sections", "isActive", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "App User",
      "description": "User profile and metadata including role, status, and subscription details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["free", "basic", "pro", "admin"] },
        "accountStatus": { "type": "string", "enum": ["active", "paused", "expired", "banned"] },
        "paymentStatus": { "type": "string", "enum": ["none", "active", "canceled", "expired", "refunded", "trial"] },
        "createdAt": { "type": "number" },
        "lastLoginAt": { "type": "number" },
        "planName": { "type": "string" },
        "planStartAt": { "type": "number" },
        "planExpireAt": { "type": "number" },
        "nextBillingAt": { "type": "number" },
        "lastPaymentAt": { "type": "number" },
        "songGeneratedCount": { "type": "number" },
        "favoriteCount": { "type": "number" },
        "adminMemo": { "type": "string" },
        "forceLogoutAt": { "type": "object", "description": "Server timestamp for force logout signal." },
        "forceLogoutReason": { "type": "string" }
      },
      "required": ["uid", "email", "role", "accountStatus", "paymentStatus", "createdAt", "songGeneratedCount", "favoriteCount"]
    },
    "CustomStructurePreset": {
      "title": "Custom Structure Preset",
      "description": "A saved custom song structure preset.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sections": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "section": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "createdAt": { "type": "number" },
        "reaction": { "type": "string", "enum": ["like", "dislike", null] }
      },
      "required": ["id", "name", "sections", "createdAt"]
    },
    "UserStructures": {
      "title": "User Song Structures",
      "description": "A document containing a list of saved song structure presets for a user.",
      "type": "object",
      "properties": {
        "structures": {
          "type": "array",
          "items": { "$ref": "CustomStructurePreset" }
        }
      },
      "required": ["structures"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles collection."
    },
    "/user_structures/{uid}": {
      "schema": "UserStructures",
      "description": "User's saved custom song structure presets."
    },
    "/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "Collection of user favorite songs."
    },
    "/user_recent_songs/{uid}": {
      "schema": "RecentSongs",
      "description": "Document containing the 5 most recent songs for a user."
    },
    "/section_tags/{tagId}": {
      "schema": "SectionTag",
      "description": "Collection of section tags managed by admins."
    },
    "/section_tags_draft/{tagId}": {
      "schema": "SectionTag",
      "description": "Draft collection of section tags for admin testing."
    },
    "/section_tags_live/{tagId}": {
      "schema": "SectionTag",
      "description": "Live collection of section tags for production use."
    }
  }
}