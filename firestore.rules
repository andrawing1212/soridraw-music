rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: favorites
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The user's UID
    //   - title: string (required, max 200 chars)
    //   - lyrics: map (required)
    //     - english: string (required, max 5000 chars)
    //     - korean: string (required, max 5000 chars)
    //   - prompt: string (required, max 2000 chars)
    //   - appliedKeywords: map (required)
    //     - genre: list of strings (required, max 10 items)
    //     - mood: list of strings (required, max 10 items)
    //     - theme: list of strings (required, max 10 items)
    //     - tempo: string (optional, max 50 chars)
    //     - vocalGender: string (optional, max 50 chars)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "andrawing1212@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['uid', 'title', 'lyrics', 'prompt', 'appliedKeywords', 'isLocked', 'createdAt']) &&
             data.keys().hasOnly(['uid', 'title', 'lyrics', 'prompt', 'appliedKeywords', 'isLocked', 'createdAt']) &&
             data.uid is string &&
             data.title is string && data.title.size() <= 200 &&
             data.lyrics is map &&
             data.lyrics.keys().hasOnly(['english', 'korean']) &&
             data.lyrics.english is string && data.lyrics.english.size() <= 10000 &&
             data.lyrics.korean is string && data.lyrics.korean.size() <= 10000 &&
             data.prompt is string && data.prompt.size() <= 5000 &&
             data.appliedKeywords is map &&
             data.appliedKeywords.keys().hasOnly(['genre', 'mood', 'theme', 'tempo', 'vocalType', 'lyricsLength', 'drumStyle', 'maleCount', 'femaleCount', 'tempoConfig']) &&
             data.appliedKeywords.genre is list && data.appliedKeywords.genre.size() <= 10 &&
             data.appliedKeywords.mood is list && data.appliedKeywords.mood.size() <= 10 &&
             data.appliedKeywords.theme is list && data.appliedKeywords.theme.size() <= 10 &&
             (!('tempo' in data.appliedKeywords) || (data.appliedKeywords.tempo is string && data.appliedKeywords.tempo.size() <= 50)) &&
             (!('vocalType' in data.appliedKeywords) || (data.appliedKeywords.vocalType is string && data.appliedKeywords.vocalType.size() <= 50)) &&
             (!('lyricsLength' in data.appliedKeywords) || (data.appliedKeywords.lyricsLength is string && data.appliedKeywords.lyricsLength.size() <= 50)) &&
             (!('drumStyle' in data.appliedKeywords) || (data.appliedKeywords.drumStyle is string && data.appliedKeywords.drumStyle.size() <= 50)) &&
             (!('maleCount' in data.appliedKeywords) || (data.appliedKeywords.maleCount is number)) &&
             (!('femaleCount' in data.appliedKeywords) || (data.appliedKeywords.femaleCount is number)) &&
             (!('tempoConfig' in data.appliedKeywords) || (
               data.appliedKeywords.tempoConfig is map &&
               data.appliedKeywords.tempoConfig.keys().hasOnly(['enabled', 'min', 'max']) &&
               data.appliedKeywords.tempoConfig.enabled is bool &&
               data.appliedKeywords.tempoConfig.min is number &&
               data.appliedKeywords.tempoConfig.max is number
             )) &&
             data.isLocked is bool &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.uid is string &&
             (data.get('email', null) == null || (data.get('email', '') is string)) &&
             data.get('role', 'free') in ['free', 'basic', 'pro', 'admin'] &&
             data.get('accountStatus', 'active') in ['active', 'paused', 'expired', 'banned'] &&
             data.get('paymentStatus', 'none') in ['none', 'active', 'canceled', 'expired', 'refunded', 'trial'] &&
             (data.get('createdAt', 0) is number || data.get('createdAt', timestamp(0)) is timestamp);
    }

    function isValidRecentSongs(data) {
      return data.keys().hasAll(['songs']) &&
             data.keys().hasOnly(['songs']) &&
             data.songs is list &&
             data.songs.size() <= 5;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /favorites/{favoriteId} {
      // Users can only read their own favorites
      allow read: if isOwner(resource.data.uid);
      
      // Users can only create favorites for themselves
      allow create: if isOwner(request.resource.data.uid) && isValidFavorite(request.resource.data);
      
      // Users can only delete their own favorites
      allow delete: if isOwner(resource.data.uid);
      
      // Only isLocked can be updated
      allow update: if isOwner(resource.data.uid) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isLocked']) &&
                      request.resource.data.isLocked is bool;
    }

    match /user_recent_songs/{uid} {
      // Users can only read their own recent songs
      allow read: if isOwner(uid);
      
      // Users can only create/update their own recent songs
      allow create, update: if isOwner(uid) && isValidRecentSongs(request.resource.data);
      
      // Users can only delete their own recent songs
      allow delete: if isOwner(uid);
    }

    match /section_tags/{tagId} {
      // Anyone can read active tags
      allow read: if true;
      // Only admins can manage tags
      allow write: if isAdmin();
    }

    match /section_tags_draft/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /section_tags_live/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{uid} {
      // Users can read/write their own profile
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      
      // Users can create their own profile as 'free' (or 'admin' if email fallback matches)
      allow create: if isOwner(uid) && 
                      isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'free' || isAdmin());
      
      // Users can update their own profile but NOT their role or account status
      allow update: if (isOwner(uid) && 
                        isValidUser(request.resource.data) && 
                        request.resource.data.get('role', 'free') == resource.data.get('role', 'free') && 
                        request.resource.data.get('accountStatus', 'active') == resource.data.get('accountStatus', 'active')) || 
                      isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}