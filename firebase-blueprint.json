{
  "entities": {
    "Favorite": {
      "title": "Favorite Song",
      "description": "A song that a user has marked as a favorite.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The UID of the user who favorited the song."
        },
        "title": {
          "type": "string",
          "description": "The title of the song."
        },
        "lyrics": {
          "type": "object",
          "description": "The lyrics of the song in English and Korean.",
          "properties": {
            "english": { "type": "string" },
            "korean": { "type": "string" }
          }
        },
        "prompt": {
          "type": "string",
          "description": "The music generation prompt."
        },
        "appliedKeywords": {
          "type": "object",
          "description": "The keywords used to generate the song.",
          "properties": {
            "genre": { "type": "array", "items": { "type": "string" } },
            "mood": { "type": "array", "items": { "type": "string" } },
            "theme": { "type": "array", "items": { "type": "string" } },
            "tempo": { "type": "string" },
            "vocalType": { "type": "string" },
            "lyricsLength": { "type": "string" },
            "drumStyle": { "type": "string" },
            "maleCount": { "type": "number" },
            "femaleCount": { "type": "number" },
            "tempoConfig": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "min": { "type": "number" },
                "max": { "type": "number" }
              }
            }
          }
        },
        "isLocked": {
          "type": "boolean",
          "description": "Whether the favorite is locked from deletion."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the favorite was created."
        }
      },
      "required": ["uid", "title", "lyrics", "prompt", "appliedKeywords", "isLocked", "createdAt"]
    },
    "RecentSongs": {
      "title": "Recent Songs",
      "description": "A list of the 5 most recent songs generated by a user.",
      "type": "object",
      "properties": {
        "songs": {
          "type": "array",
          "items": { "$ref": "Favorite" },
          "description": "The list of recent songs."
        }
      },
      "required": ["songs"]
    },
    "SectionTag": {
      "title": "Section Tag",
      "description": "A tag that can be applied to a song section.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "tier": { "type": "string", "enum": ["free", "pro", "pro+"] },
        "sections": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "label", "description", "tier", "sections", "isActive", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "Collection of user favorite songs."
    },
    "/user_recent_songs/{uid}": {
      "schema": "RecentSongs",
      "description": "Document containing the 5 most recent songs for a user."
    },
    "/section_tags/{tagId}": {
      "schema": "SectionTag",
      "description": "Collection of section tags managed by admins."
    }
  }
}